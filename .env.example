# Set ONE or more API keys (first match is used for auto-detection):
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: override default model
# MODEL=anthropic/claude-opus-4-6

# Optional: set default provider for review (overrides auto-detection)
# REVIEW_PROVIDER=openrouter
# Choices: openrouter, openai, anthropic, gemini, mistral
# Can also be set via --provider CLI flag
